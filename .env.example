# Copy to .env and adjust. .env is gitignored — never commit real secrets.

# --- Gateway HTTP server ---
GATEWAY_PORT=8080            # Port the gateway listens on (host + container)
GATEWAY_HOST=0.0.0.0         # Bind address; 0.0.0.0 to be reachable from host

# --- Postgres (stood up in Step 0, used by code in later steps) ---
POSTGRES_HOST=postgres       # Hostname; "postgres" is the compose service name
POSTGRES_PORT=5432           # Postgres port
POSTGRES_USER=gateway        # Database user
POSTGRES_PASSWORD=changeme   # Database password — set a real one in .env
POSTGRES_DB=gateway          # Database name

# --- Redis (stood up in Step 0, used by code in later steps) ---
REDIS_URL=redis://redis:6379 # Redis connection URL ("redis" is the service name)

# --- Step 1: downstream MCP server (transparent proxy target) ---
# The gateway launches this command as a stdio subprocess and proxies to it.
# Leave UNSET to use the default: the locally-installed filesystem reference
# server (node_modules/@modelcontextprotocol/server-filesystem) run via the
# current Node binary, serving the gateway's working directory.
# Override both to point at a different downstream server. Args are space-
# separated; for the filesystem server the last arg is the directory it serves.
#MCP_DOWNSTREAM_COMMAND=npx                                       # e.g. fetch the server on demand instead of using the local install
#MCP_DOWNSTREAM_ARGS=-y @modelcontextprotocol/server-filesystem ./  # Downstream command args (last arg = served directory)
