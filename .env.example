# Copy to .env and adjust. .env is gitignored — never commit real secrets.

# --- Gateway HTTP server ---
GATEWAY_PORT=8080            # Port the gateway listens on (host + container)
GATEWAY_HOST=0.0.0.0         # Bind address; 0.0.0.0 to be reachable from host

# --- Postgres (stood up in Step 0, used by code in later steps) ---
POSTGRES_HOST=postgres       # Hostname; "postgres" is the compose service name
POSTGRES_PORT=5432           # Postgres port
POSTGRES_USER=gateway        # Database user
POSTGRES_PASSWORD=changeme   # Database password — set a real one in .env
POSTGRES_DB=gateway          # Database name

# --- Redis (stood up in Step 0, used by code in later steps) ---
REDIS_URL=redis://redis:6379 # Redis connection URL ("redis" is the service name)
