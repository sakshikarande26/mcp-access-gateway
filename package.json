{
  "name": "mcp-access-gateway",
  "version": "0.0.0",
  "description": "Self-hosted access gateway between AI agents and the MCP tool servers they call.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "mcp:stdio": "node dist/mcp/stdio.js",
    "mcp:stdio:dev": "tsx src/mcp/stdio.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
